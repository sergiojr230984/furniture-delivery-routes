# Supabase — get these from your project at https://app.supabase.com  →  Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Service-role key — server-only. NEVER expose to the browser.
# Used for admin actions like creating driver/staff user accounts.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
