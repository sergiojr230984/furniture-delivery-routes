# Supabase — get these from your project at https://app.supabase.com  →  Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Service-role key — server-only. NEVER expose to the browser.
# Used for admin actions like creating driver/staff user accounts.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Twilio SMS ────────────────────────────────────────────────────────────────
# Sign up at https://twilio.com → buy a number → copy from Console Dashboard.
# Leave blank to disable automatic customer SMS notifications.
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_FROM_NUMBER="+1xxxxxxxxxx"

# ── Google Calendar ───────────────────────────────────────────────────────────
# 1. Create a Service Account in Google Cloud Console (enable Calendar API).
# 2. Download the JSON key → base-64 encode it:
#      base64 -i service-account.json | tr -d '\n'
# 3. Share your Google Calendar with the service account's email address
#    (grant "Make changes to events").
# 4. Paste the calendar ID from Calendar Settings → Integrate calendar.
# Leave blank to disable automatic route calendar sync.
GOOGLE_SERVICE_ACCOUNT_JSON="base64-encoded-service-account-json"
GOOGLE_CALENDAR_ID="your-calendar-id@group.calendar.google.com"
